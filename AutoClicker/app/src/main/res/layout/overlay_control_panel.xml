<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD111111"
    android:padding="10dp"
    android:elevation="12dp">

    <!-- 拖曳 Handle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:text="⠿ AutoClicker"
        android:textColor="#FF3333"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="6dp" />

    <!-- 狀態 -->
    <TextView
        android:id="@+id/tvState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="■ STOPPED"
        android:textColor="#888888"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <!-- 速度 / 點擊數 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingBottom="8dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="速度" android:textColor="#555555" android:textSize="9sp" />
            <TextView android:id="@+id/tvSpeed"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="10ms" android:textColor="#FFFFFF"
                android:textSize="11sp" android:fontFamily="monospace" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="點擊數" android:textColor="#555555" android:textSize="9sp" />
            <TextView android:id="@+id/tvClicks"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#FFFFFF"
                android:textSize="11sp" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- 按鈕 -->
    <Button android:id="@+id/btnStart"
        android:layout_width="match_parent" android:layout_height="32dp"
        android:text="Start" android:textSize="12sp"
        android:backgroundTint="#CC2200"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp" />

    <Button android:id="@+id/btnPause"
        android:layout_width="match_parent" android:layout_height="32dp"
        android:text="Pause" android:textSize="12sp"
        android:backgroundTint="#335500"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp" />

    <Button android:id="@+id/btnStop"
        android:layout_width="match_parent" android:layout_height="32dp"
        android:text="Stop" android:textSize="12sp"
        android:backgroundTint="#222222"
        android:textColor="#FF4444" />

</LinearLayout>
